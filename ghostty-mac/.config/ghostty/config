theme = Gruvbox Material

# command = zsh -c tmux

font-family = BlexMono Nerd Font
font-style = Medium
font-size = 13
font-feature = -calt, -liga, -dlig

cursor-style = block
cursor-style-blink = false

shell-integration-features = no-cursor

macos-titlebar-style = tabs
macos-option-as-alt = left
window-vsync = true

window-new-tab-position = end

# keybind = cmd+j=goto_split:next
# keybind = cmd+k=goto_split:previous

keybind = cmd+w=close_surface
keybind = cmd+o=new_split:auto
# keybind = cmd+f=toggle_split_zoom

keybind = super+enter=new_split:auto

window-padding-x = 8
window-padding-y = 8

keybind = super+physical:one=text:\x1b1
keybind = super+physical:two=text:\x1b2
keybind = super+physical:three=text:\x1b3
keybind = super+physical:four=text:\x1b4
keybind = super+physical:five=text:\x1b5
keybind = super+physical:six=text:\x1b6
keybind = super+physical:seven=text:\x1b7
keybind = super+physical:eight=text:\x1b8
keybind = super+physical:nine=text:\x1b9
keybind = super+physical:zero=text:\x1b0

keybind = super+t=text:\x1bt
keybind = super+f=text:\x1bf
keybind = super+s=text:\x1bs
keybind = super+j=text:\x1bj
keybind = super+k=text:\x1bk
keybind = super+enter=text:\x1b\r
